# Copy this file to `key.properties` (in the android/ folder) and fill in your values.
# DO NOT COMMIT key.properties to git. Add it to .gitignore (already there for this project).
#
# To generate the keystore, run this once from the android/ folder:
#
#   keytool -genkey -v -keystore ~/upload-keystore.jks \
#     -keyalg RSA -keysize 2048 -validity 10000 -alias upload
#
# You'll be prompted for a password and your name/org. Remember the password —
# if you lose it you can never update the app on Play Store again.
# Back up upload-keystore.jks somewhere safe (password manager, encrypted drive).

storePassword=YOUR_KEYSTORE_PASSWORD
keyPassword=YOUR_KEY_PASSWORD
keyAlias=upload
storeFile=/Users/jj/upload-keystore.jks
